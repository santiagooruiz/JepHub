// Esquema Prisma — Sprint 1 (multi-tenant + RBAC).
// El esquema v1 completo (dominio CRM) está en docs/PLAN-IMPLEMENTACION.md
// y se irá materializando en los Sprints 3+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PASSWORD_CHANGE
}

enum PersonType {
  NATURAL
  JURIDICA
}

enum EntityType {
  CLIENT
  OPPORTUNITY
  QUOTE
  ORDER
  DESIGN
  SPECIAL
}

enum CloseProb {
  UNDEFINED
  HIGH
  FIXED
}

enum ApprovalKind {
  INGRESO
  FABRICACION
  INSTALACION
  FACTURACION
}

// ─────────────────────────── Tenancy ───────────────────────────
model Company {
  id         String      @id @default(cuid())
  name       String
  createdAt  DateTime    @default(now())
  users      User[]
  roles      Role[]
  parameters    Parameter[]
  categories    Category[]
  tags          Tag[]
  clients       Client[]
  opportunities Opportunity[]
  quotes        Quote[]
  products      Product[]
  orders        Order[]
  designRequests DesignRequest[]
  specialDesigns SpecialDesign[]
}

// ─────────────────────────── Config & Catálogos ───────────────────────────

// Store clave-valor JSON que define enums/estados del sistema (con icon/color).
model Parameter {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
}

// Catálogo genérico parametrizable por entidad (channel, client, ...).
model Category {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  entity    String
  name      String
  createdAt DateTime @default(now())

  @@unique([companyId, entity, name])
}

model Tag {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  createdAt DateTime @default(now())

  @@unique([companyId, name])
}

// ─────────────────────────── Seguridad (RBAC) ───────────────────────────
model Role {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  name        String
  seatLimit   Int? // cupo/licenciamiento (usados / límite)
  users       User[]
  permissions RolePermission[]

  @@unique([companyId, name])
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique // {modulo}.{accion} → clients.create
  name  String // etiqueta legible ("Crear Cliente")
  roles RolePermission[]
}

// Permiso × Rol, con restricción/scope por rol.
model RolePermission {
  roleId       String
  permissionId String
  active       Boolean    @default(false)
  restriction  String? // scope, p.ej. "own" (solo registros propios)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─────────────────────────── Usuarios ───────────────────────────
model User {
  id               String     @id @default(cuid())
  companyId        String
  company          Company    @relation(fields: [companyId], references: [id])
  name             String
  email            String     @unique
  passwordHash     String?
  roleId           String?
  role             Role?      @relation(fields: [roleId], references: [id])
  language         String     @default("es")
  status           UserStatus @default(ACTIVE)
  cargoActual      String?
  numeroDocumento  String?
  numeroTelefonico String?
  codven           String? // código vendedor primario (ERP ofimática) = codvens[0]
  codvens          String[] @default([]) // códigos vendedor (un asesor puede tener varios, p.ej. EXTERIOR y LOCAL)
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  clientsAdvised     Client[]      @relation("ClientAdvisor")
  activities         Activity[]
  opportunitiesAdvised Opportunity[] @relation("OppAdvisor")
  quotesRegistered   Quote[]       @relation("QuoteRegisteredBy")
  ordersAdvised      Order[]       @relation("OrderAdvisor")
  orderApprovals     OrderApproval[]
  designsAssigned      DesignRequest[]        @relation("DesignAssignee")
  designsRequested     DesignRequest[]        @relation("DesignRequester")
  specialDesignsCreated SpecialDesign[]       @relation("SpecialCreator")
  specialMessages      SpecialDesignMessage[]
  designMessages       DesignRequestMessage[]
  notifications        Notification[]
}

// ─────────────────────────── Clientes ───────────────────────────
model Client {
  id                   String     @id @default(cuid())
  companyId            String
  company              Company    @relation(fields: [companyId], references: [id])
  numero               Int
  personType           PersonType @default(JURIDICA)
  estado               String     @default("Prospecto")
  // Persona Natural
  nombres              String?
  apellidos            String?
  // Persona Jurídica
  nombreComercial      String?
  razonSocial          String?
  // Comunes
  email                String?
  telefono             String?
  tipoDocumento        String?
  numeroDocumento      String?
  direccion            String?
  complementoDireccion String?
  pais                 String?    @default("Colombia")
  ciudad               String?
  observaciones        String?
  priceListId          String?
  priceList            PriceList? @relation(fields: [priceListId], references: [id])
  sectorId             String?
  sector               Sector?    @relation(fields: [sectorId], references: [id])
  subSectorId          String?
  subSector            SubSector? @relation(fields: [subSectorId], references: [id])
  canal                String?
  saldoCartera         Decimal?   @db.Decimal(15, 2)
  advisorId            String?
  advisor              User?      @relation("ClientAdvisor", fields: [advisorId], references: [id])
  codven               String?    // asesor del ERP (VENDEN.CODVEN)
  codprecio            String?    // lista de precio del ERP (MTPRECIO.CODPRECIO)
  ultimaInteraccion    DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?
  contacts             Contact[]
  activities           Activity[]
  attachments          Attachment[]
  opportunities        Opportunity[]
  quotes               Quote[]
  orders               Order[]

  @@unique([companyId, numero])
  @@index([companyId, estado])
}

model Contact {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nombre      String
  email       String?
  telefono    String?
  cargo       String?
  observacion String?
}

// ─────────────────────────── Oportunidades ───────────────────────────
// (interna: "proyecto" en el CRM original)
model Opportunity {
  id                    String     @id @default(cuid())
  companyId             String
  company               Company    @relation(fields: [companyId], references: [id])
  numero                Int
  clientId              String
  client                Client     @relation(fields: [clientId], references: [id])
  nombre                String
  contacto              String?
  cantidadPuestos       Int?
  areaCubrir            Decimal?   @db.Decimal(12, 2)
  observaciones         String?
  advisorId             String?
  advisor               User?      @relation("OppAdvisor", fields: [advisorId], references: [id])
  fechaCierreProyectada DateTime?
  estado                String     @default("No Cotizada")
  probabilidad          CloseProb  @default(UNDEFINED)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?
  quotes                Quote[]
  orders                Order[]

  @@unique([companyId, numero])
  @@index([companyId, estado])
}

model Sector {
  id         String      @id @default(cuid())
  name       String      @unique
  subsectors SubSector[]
  clients    Client[]
}

model SubSector {
  id       String   @id @default(cuid())
  name     String
  sectorId String
  sector   Sector   @relation(fields: [sectorId], references: [id])
  clients  Client[]

  @@unique([sectorId, name])
}

model PriceList {
  id      String   @id @default(cuid())
  name    String   @unique
  clients Client[]
}

// ─────────────── Transversales: Actividad & Adjuntos ───────────────
// Se relacionan opcionalmente con cliente/oportunidad/cotización/pedido.
model Activity {
  id            String     @id @default(cuid())
  companyId     String
  entityType    EntityType
  clientId      String?
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  opportunityId String?
  quoteId       String?
  orderId       String?
  designRequestId String?
  specialDesignId String?
  accion        String
  fechaHora     DateTime
  observaciones String?
  userId        String?
  user          User?      @relation(fields: [userId], references: [id])
  auto          Boolean    @default(false)
  createdAt     DateTime   @default(now())

  @@index([entityType, clientId])
}

model Attachment {
  id            String     @id @default(cuid())
  companyId     String
  entityType    EntityType
  clientId      String?
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  opportunityId String?
  quoteId       String?
  orderId       String?
  designRequestId String?
  designRequest   DesignRequest? @relation(fields: [designRequestId], references: [id])
  specialDesignId String?
  tipoArchivo   String?
  bucket        String     @default("archivos")
  observaciones String?
  url           String
  // Subida binaria (MinIO/S3): clave en el bucket + metadatos del archivo.
  // Si storageKey es null el adjunto es solo una URL registrada a mano.
  storageKey    String?
  nombre        String?
  mimeType      String?
  size          Int?
  // Aprobación del archivo (p.ej. ficha técnica en el Backlog Diseño)
  estado          String?   // APROBADA | RECHAZADA
  aprobadoPor     String?
  fechaAprobacion DateTime?
  firma           String?   // imagen de la firma (URL / data URI)
  // Borrado suave: el archivo sigue visible como [BORRADA] en el historial
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())

  @@index([entityType, clientId])
}

// ─────────────────────────── Productos y Cotizaciones ───────────────────────────
model Product {
  id         String     @id @default(cuid())
  companyId  String
  company    Company    @relation(fields: [companyId], references: [id])
  codigo     String
  nombre     String
  tipo       String?
  referencia String?
  imagen     String?
  precioBase Decimal?   @db.Decimal(15, 2)
  // Acabados por defecto (pueden quedar "POR DEFINIR")
  formica    String?
  canto      String?
  herraje    String?
  items      LineItem[]

  @@unique([companyId, codigo])
}

// (interna: "proposal" en el CRM original)
model Quote {
  id               String       @id @default(cuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id])
  numero           Int
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id])
  opportunityId    String?
  opportunity      Opportunity? @relation(fields: [opportunityId], references: [id])
  registeredById   String?
  registeredBy     User?        @relation("QuoteRegisteredBy", fields: [registeredById], references: [id])
  estado           String       @default("Pendiente cotización")
  probabilidad     CloseProb    @default(UNDEFINED)
  formaPago        String?
  tiempoEntrega    String?
  ordenCompra      String?
  direccionEnvio   String?
  observacion      String?
  fechaVencimiento DateTime?
  subtotal         Decimal      @default(0) @db.Decimal(15, 2)
  impuesto         Decimal      @default(0) @db.Decimal(15, 2)
  total            Decimal      @default(0) @db.Decimal(15, 2)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  items            LineItem[]
  signature        Signature?
  order            Order?
  designRequests   DesignRequest[]

  @@unique([companyId, numero])
  @@index([companyId, estado])
}

// ─────────────────────────── Pedidos ───────────────────────────
// (interna: "order" en el CRM original)
model Order {
  id                  String          @id @default(cuid())
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id])
  numero              Int
  clientId            String
  client              Client          @relation(fields: [clientId], references: [id])
  opportunityId       String?
  opportunity         Opportunity?    @relation(fields: [opportunityId], references: [id])
  quoteId             String?         @unique
  quote               Quote?          @relation(fields: [quoteId], references: [id])
  advisorId           String?
  advisor             User?           @relation("OrderAdvisor", fields: [advisorId], references: [id])
  estado              String          @default("Pendiente Ingreso")
  tipoProducto        String          @default("Estándar")
  requiereInstalacion Boolean         @default(false)
  formaPago           String?
  ordenCompra         String?
  direccionEnvio      String?
  subtotal            Decimal         @default(0) @db.Decimal(15, 2)
  impuesto            Decimal         @default(0) @db.Decimal(15, 2)
  total               Decimal         @default(0) @db.Decimal(15, 2)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  items               LineItem[]
  approvals           OrderApproval[]
  erpSync             ErpSync?
  specialDesigns      SpecialDesign[]
  designRequests      DesignRequest[]

  @@unique([companyId, numero])
  @@index([companyId, estado])
}

model OrderApproval {
  id           String       @id @default(cuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kind         ApprovalKind
  aprobado     Boolean      @default(false)
  approvedById String?
  approvedBy   User?        @relation(fields: [approvedById], references: [id])
  observacion  String?
  fecha        DateTime?

  @@unique([orderId, kind])
}

// Integración con el ERP "ofimática" (sincronización asíncrona vía worker BullMQ).
model ErpSync {
  id                     String    @id @default(cuid())
  orderId                String    @unique
  order                  Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  nPedidoOfimatica       String?
  // NRODCTO del PEDIDO (PD) que el ERP generó desde nuestra CV (solo lectura;
  // se detecta con TRADE.TIPODCTOPC='CV' AND NROSOLI=<CV>).
  nroPedidoErp           String?
  identificadorCotizacion String?
  // PENDIENTE · ENCOLADO · ENVIADO · ERROR
  estadoEnvio            String?
  fechaEnvio             DateTime?
  fechaCreacion          DateTime?
  fechaTapiceria         DateTime?
  fechaListo             DateTime?
  fechaDespacho          DateTime?
  notasGenerales         String?
  ultimoError            String?
  intentos               Int       @default(0)
}

// Notificación in-app (eventos del sistema: hitos ofimática, etc.).
model Notification {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  tipo      String   // ofimatica · sistema · ...
  titulo    String
  cuerpo    String?
  href      String?
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([companyId, userId, leida])
}

// Firma electrónica remota del cliente para aprobar una cotización.
model Signature {
  id             String    @id @default(cuid())
  quoteId        String    @unique
  quote          Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  token          String    @unique
  estado         String    @default("pendiente") // pendiente | firmada | rechazada
  firmanteNombre String?
  firmanteEmail  String?
  firmaImagen    String?   @db.Text // PNG data-URL: dibujada o extraída de archivo (imagen/PDF)
  firmadaEn      DateTime?
  createdAt      DateTime  @default(now())
}

model LineItem {
  id                    String   @id @default(cuid())
  quoteId               String?
  quote                 Quote?   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  orderId               String?
  order                 Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId             String?
  product               Product? @relation(fields: [productId], references: [id])
  imagen                String?
  referencia            String?
  descripcion           String?
  precio                Decimal  @db.Decimal(15, 2)
  cantidad              Int
  descuentoPct          Decimal  @default(0) @db.Decimal(5, 2)
  precioConDesc         Decimal  @db.Decimal(15, 2)
  acabados              String?
  observacionesInternas String?
  total                 Decimal  @db.Decimal(15, 2)
}

// ─────────────────────────── Diseño ───────────────────────────
// Backlog Diseño (proceso ISO 9001 PR-DI-01). Recibe solicitudes desde
// cotizaciones ("Solicitar planos") o como productos [INTERNO].
model DesignRequest {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  numero      Int
  // Origen: cotización, pedido (pendiente ficha técnica) o desarrollo interno
  quoteId     String?
  quote       Quote?   @relation(fields: [quoteId], references: [id])
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  clientId    String?
  interno     Boolean  @default(false)
  designerId  String?
  designer    User?    @relation("DesignAssignee", fields: [designerId], references: [id])
  // Quién solicitó el diseño (para notificarle cuando haya entregables)
  requestedById String?
  requestedBy   User?  @relation("DesignRequester", fields: [requestedById], references: [id])
  imagen      String?
  descripcion String?
  // Planificación de diseño & desarrollo (PR-DI-01)
  datosEntrada          String?
  requisitosTecnicos    String?
  requisitosFuncionales String?
  posiblesFallos        String?
  requisitosLegales     String?
  disenosPrevios        String?
  estado      String   @default("PT precio comercial")
  // Precio comercial del producto (etapa "PT precio comercial"; el asesor lo
  // negocia con el cliente en "Especial sin aprobar cliente")
  precioVentaPublico Decimal? @db.Decimal(15, 2)
  precioVentaDto     Decimal? @db.Decimal(15, 2)
  cantRequerida      Int?
  // Entregables de diseño (URL/nombre de archivo)
  despiece       String?
  armadoGeneral  String?
  planosTecnicos String?
  nPedidoOfimatica String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  special     SpecialDesign?
  messages    DesignRequestMessage[]
  attachments Attachment[]

  @@unique([companyId, numero])
  @@index([companyId, estado])
}

// Chat interno de la solicitud de diseño (tab "Mensajes" del backlog).
model DesignRequestMessage {
  id              String        @id @default(cuid())
  designRequestId String
  designRequest   DesignRequest @relation(fields: [designRequestId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  body            String
  createdAt       DateTime      @default(now())
}

// Biblioteca Especiales: catálogo de piezas/productos a medida (CÓDIGO ESPECIAL).
model SpecialDesign {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  codigo          String
  designRequestId String?        @unique
  designRequest   DesignRequest? @relation(fields: [designRequestId], references: [id])
  orderId         String?
  order           Order?         @relation(fields: [orderId], references: [id])
  creadorId       String?
  creador         User?          @relation("SpecialCreator", fields: [creadorId], references: [id])
  tipo            String?
  descripcion     String?
  imagen          String?
  estado          String         @default("EN DISEÑO")
  precioVentaPublico Decimal?    @db.Decimal(15, 2)
  precioVentaDto     Decimal?    @db.Decimal(15, 2)
  cantRequerida   Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  messages        SpecialDesignMessage[]

  @@unique([companyId, codigo])
}

// Chat interno del diseño especial (tab "Mensajes").
model SpecialDesignMessage {
  id              String        @id @default(cuid())
  specialDesignId String
  specialDesign   SpecialDesign @relation(fields: [specialDesignId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  body            String
  createdAt       DateTime      @default(now())
}
