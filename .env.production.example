# Plantilla de entorno de PRODUCCIÓN. Copiar a `.env.production` y rellenar.
# NUNCA commitear el archivo real (está en .gitignore).
#
#   cp .env.production.example .env.production
#   # editar valores y generar secretos:  openssl rand -base64 48

# ── Dominio público (Caddy) ──
APP_DOMAIN=crm.jepmobiliari.com
APP_URL=https://crm.jepmobiliari.com

# ── Base de datos (interna a la red docker) ──
POSTGRES_USER=jep
POSTGRES_PASSWORD=cambiar-por-password-fuerte
POSTGRES_DB=jephub
DATABASE_URL=postgresql://jep:cambiar-por-password-fuerte@postgres:5432/jephub?schema=public

# ── Redis (interno) ──
REDIS_URL=redis://redis:6379

# ── Auth (JWT de sesión). Mínimo 32 chars; usar `openssl rand -base64 48`. ──
AUTH_SECRET=generar-un-secreto-largo-y-aleatorio

# ── Integración ofimática (ERP) ──
OFIMATICA_WEBHOOK_SECRET=generar-otro-secreto-para-el-webhook
OFIMATICA_MOCK_DELAYS=10000,20000,30000
