# Base de datos (PostgreSQL)
# El contenedor Docker publica en el puerto 5433 del host (para no chocar
# con un PostgreSQL nativo que use 5432). Ver docker-compose.yml.
DATABASE_URL="postgresql://jep:jep@localhost:5433/jephub?schema=public"

# Redis (colas BullMQ / worker ofimática)
REDIS_URL="redis://localhost:6379"

# Auth
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL pública de la app (para el link de firma del cliente y callbacks del worker)
APP_URL="http://localhost:3000"

# Almacenamiento de archivos (MinIO / S3-compatible). Ver docker-compose.yml.
# Si se dejan vacías, la subida binaria queda deshabilitada (solo registro de URL).
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="jep"
S3_SECRET_KEY="jep-minio-dev"
S3_BUCKET="jephub"

# Integración ofimática (ERP)
# Secreto compartido para autenticar el webhook de hitos (ERP → /api/ofimatica/webhook).
OFIMATICA_WEBHOOK_SECRET="cambia-esto-por-un-secreto-de-webhook"
# Retrasos (ms) de los hitos simulados por el cliente ERP mock (tapicería, listo, despacho).
OFIMATICA_MOCK_DELAYS="10000,20000,30000"

# BD del ERP ofimática (SQL Server). Si se dejan vacías, se usa el cliente
# simulado. Ver docs/INTEGRACION-OFIMATICA.md. La clave va entre comillas
# SIMPLES para que dotenv-expand no interprete "$".
# OFIMATICA_DB_HOST="10.10.1.4"
# OFIMATICA_DB_PORT="1433"
# OFIMATICA_DB_NAME="PROTOTIPO2016"
# OFIMATICA_DB_USER="gestion_produccion"
# OFIMATICA_DB_PASSWORD='...'
# Frecuencia (ms) del polling de hitos en TRADEMAS (default 5 min).
# OFIMATICA_POLL_MS="300000"
# Parámetros de la cotización 'CV' creada en el ERP vía stored procedures.
# OFIMATICA_PASSWORDIN="JEPHUB"   # estampa de usuario en el ERP (PASSWORDIN)
# OFIMATICA_CODCC="051501"        # centro de costo (CENTCOS)
# OFIMATICA_BODEGA="PTCAL"        # bodega base (se ajusta por TIPOINV del producto)
# OFIMATICA_TARIVA="0"            # código de tarifa de IVA (MVTRADE.TARIVA)
# OFIMATICA_PORIVA="19"           # porcentaje de IVA
