# Base de datos (PostgreSQL)
# El contenedor Docker publica en el puerto 5433 del host (para no chocar
# con un PostgreSQL nativo que use 5432). Ver docker-compose.yml.
DATABASE_URL="postgresql://jep:jep@localhost:5433/jephub?schema=public"

# Redis (colas BullMQ / worker ofimática)
REDIS_URL="redis://localhost:6379"

# Auth
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL pública de la app (para el link de firma del cliente y callbacks del worker)
APP_URL="http://localhost:3000"

# Integración ofimática (ERP)
# Secreto compartido para autenticar el webhook de hitos (ERP → /api/ofimatica/webhook).
OFIMATICA_WEBHOOK_SECRET="cambia-esto-por-un-secreto-de-webhook"
# Retrasos (ms) de los hitos simulados por el cliente ERP mock (tapicería, listo, despacho).
OFIMATICA_MOCK_DELAYS="10000,20000,30000"
